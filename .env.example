# Supabase REST API (NOT the postgres connection string)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_jwt_here

# Optional: direct Postgres pooler URL (migrations/debug only)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# LLM + reranking
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
COHERE_API_KEY=...

# Embeddings (local, no API key)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# RAG tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=50
RERANK_TOP_K=5
MAX_CITATIONS=4
HYBRID_RRF_K=60

# Data
CUAD_JSON_PATH=data/CUAD_v1.json
CUAD_SEED_LIMIT=20
